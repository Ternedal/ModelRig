+	Nonce    string `json:"nonce"`
+}
+
+func issueScheduleApprovalToken(privateKeyText, binding string, now time.Time) (string, int64, error) {
+	if len(binding) != 64 {
+		return "", 0, errors.New("worker returned an invalid approval binding")
