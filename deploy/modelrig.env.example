# ModelRig environment reference. Copy to modelrig.env in the ModelRig root and edit, or set these in your
# shell / service manager. The backend and worker read them from the environment.

# ---- backend (Go) ----
MODELRIG_HOST=0.0.0.0                      # bind address. 0.0.0.0 for LAN/Android. NOT 127.0.0.1.
MODELRIG_PORT=8080
MODELRIG_OLLAMA_URL=http://127.0.0.1:11434 # where Ollama listens
# MODELRIG_OLLAMA_KEY=                       # set (+ point OLLAMA_URL at https://ollama.com) to use Ollama Cloud
MODELRIG_WORKER_URL=http://127.0.0.1:8099  # where the RAG worker listens
MODELRIG_DATA=./modelrig-data.json         # device + pairing store
MODELRIG_PAIRING_TTL=300                    # pairing code lifetime (seconds)
MODELRIG_CLAIM_MAX=10                       # max pair/claim attempts per IP / 5 min
# MODELRIG_ADMIN_KEY=change-me             # if set, pair/start requires X-Admin-Key
# MODELRIG_CONFIG=./config.json            # optional JSON config file
KALIV_SCHEDULER_API=0                       # 1 = expose authenticated /api/v1/schedules routes to paired devices
# Generate this Ed25519 pair once with: python scripts/generate_scheduler_approval_keys.py
# The private seed is backend-only. The supervisor and run-windows.ps1 remove it before starting the worker.
# KALIV_SCHEDULER_APPROVAL_PRIVATE_KEY=<base64 Ed25519 private seed>
# The worker receives only this public verification key and therefore cannot mint human consent.
# KALIV_SCHEDULER_APPROVAL_PUBLIC_KEY=<base64 Ed25519 public key>

# ---- worker (Python) ----
MODELRIG_OLLAMA_URL=http://127.0.0.1:11434 # (worker reads the same var)
MODELRIG_EMBED_MODEL=nomic-embed-text
MODELRIG_GEN_MODEL=qwen2.5-coder:7b
MODELRIG_OLLAMA_TIMEOUT=60
MODELRIG_DB=./modelrig-rag.db
KALIV_TOOLS_ENABLED=1                       # 1 = agent/tool layer on (the appliance wants it on)
KALIV_SCHEDULER=0                           # 1 = start local scheduler runner; API flag above is separate
