<?xml version="1.0" encoding="utf-8"?>
<!--
  Keep Kaliv's local data off Google Drive / device transfer. The credentials are
  already Keystore-encrypted (and the Keystore key does not restore to another
  device, so an exported token_enc is useless), but conversations, presets and
  system prompts are plaintext and belong on the device only ("alt lokalt").
  Android 12+ uses this file (android:dataExtractionRules).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="modelrig.xml"/>
        <exclude domain="database" path="modelrig.db"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="modelrig.xml"/>
        <exclude domain="database" path="modelrig.db"/>
    </device-transfer>
</data-extraction-rules>
