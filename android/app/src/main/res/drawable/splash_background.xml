<?xml version="1.0" encoding="utf-8"?>
<!-- Cold-start window background, drawn before any Kotlin runs. Uses the
     kaliv_splash_bg colour, which the OS resolves light (values/) or dark
     (values-night/) from the SYSTEM theme, the only signal available this
     early. The ankh mark is centred, matching the launcher icon. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/kaliv_splash_bg" />
    <item
        android:drawable="@drawable/ic_launcher_foreground"
        android:gravity="center"
        android:width="180dp"
        android:height="180dp" />
</layer-list>
