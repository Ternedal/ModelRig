# Agent 3.0 on-rig validation: local rolling report with host/run identifiers.
# Review and copy a successful run to a dated evidence filename before committing.
/validation/agent3-rig-validation-latest.json
/validation/agent3-rig-validation-latest.json.tmp

# Physical campaign: rolling reports and manually completed lifecycle work stay
# on the rig. Only manually reviewed, dated campaign evidence may be committed.
/validation/rig-preflight-latest.json
/validation/rig-preflight-latest.json.tmp
/validation/agent3-model-eval-latest.json
/validation/agent3-model-eval-latest.json.tmp
